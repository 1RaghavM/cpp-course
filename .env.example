# Supabase
# Postgres + Auth (magic-link). URL + anon key are public; service role bypasses RLS — server-only.
NEXT_PUBLIC_SUPABASE_URL=<placeholder>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<placeholder>
SUPABASE_SERVICE_ROLE_KEY=<placeholder>

# Anthropic Claude (lesson + exercise generation)
# Haiku for lesson summary + exercise generation, Sonnet for tutor streaming.
ANTHROPIC_API_KEY=<placeholder>

# Judge0 (C++ sandbox via RapidAPI shared host — TODO: self-host before prod)
# Currently pointed at the RapidAPI judge0-ce shared host. Replace with self-hosted gVisor VM before launch.
JUDGE0_URL=<placeholder>
JUDGE0_AUTH_TOKEN=<placeholder>

# Google Gemini (tutor chat model)
# Used by the streaming tutor route as the chat model.
GOOGLE_GENERATIVE_AI_API_KEY=<placeholder>

# BYOAK: 32-byte random key, base64-encoded. Generate with: openssl rand -base64 32
API_KEY_ENCRYPTION_SECRET=<placeholder>

# ---------------------------------------------------------------------------
# Local git pre-commit hook
# ---------------------------------------------------------------------------
# A pre-commit hook lives at .githooks/pre-commit that blocks committing any
# .env or .env.local file (only .env.example is allowed). Enable it locally:
#
#   git config core.hooksPath .githooks
#
# This is a per-clone setting; each contributor must run it once.
