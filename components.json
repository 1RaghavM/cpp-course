{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "base-vega",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "tailwind.config.ts",
    "css": "app/globals.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "menuColor": "default",
  "menuAccent": "subtle",
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "registries": {
    "@8starlabs": "https://ui.8starlabs.com/r/{name}.json",
    "@ai-elements": "https://ai-sdk.dev/elements/api/registry/{name}.json",
    "@aicanvas": "https://aicanvas.me/r/{name}.json",
    "@8starlabs-ui": "https://ui.8starlabs.com/r/{name}.json",
    "@basecn": "https://basecn.dev/r/{name}.json",
    "@abui": "https://www.abui.io/r/{name}.json"
  }
}
